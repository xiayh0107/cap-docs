{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cap-spec.org/schemas/core/cap.core.binding.v1.schema.json",
  "title": "CAP-Core Binding v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "id", "type", "target", "status"],
  "properties": {
    "schema": { "const": "cap.core.binding.v1" },
    "id": { "type": "string", "minLength": 1 },
    "type": {
      "type": "string",
      "enum": ["runtime", "resource", "service", "policy", "evidence", "digest", "transport", "data-plane", "schema"]
    },
    "target": { "type": "string", "minLength": 1 },
    "standard": { "type": ["string", "null"] },
    "standardVersion": { "type": ["string", "null"] },
    "profile": { "type": ["string", "null"] },
    "constraints": { "type": "object", "additionalProperties": true },
    "integrity": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "freshness": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "status": {
      "type": "string",
      "enum": ["candidate", "resolved", "denied", "stale", "unavailable", "deferred"]
    },
    "evidenceRefs": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
