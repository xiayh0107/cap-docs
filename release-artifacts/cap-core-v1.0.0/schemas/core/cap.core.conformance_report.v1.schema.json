{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cap-spec.org/schemas/core/cap.core.conformance_report.v1.schema.json",
  "title": "CAP-Core Conformance Report v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "validator", "status", "targetLevel", "ok", "fixtures", "negativeSuites", "unsupportedFeatures"],
  "properties": {
    "schema": { "const": "cap.core.conformance_report.v1" },
    "validator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "status": { "type": "string", "minLength": 1 },
    "targetLevel": { "type": "string", "enum": ["L0", "L1", "L2", "L3", "L4"] },
    "ok": { "type": "boolean" },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/fixtureResult" }
    },
    "negativeSuites": {
      "type": "array",
      "items": { "$ref": "#/$defs/negativeSuite" }
    },
    "unsupportedFeatures": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "diagnostic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "path", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["category", "ok", "errorCodes", "warningCodes"],
      "properties": {
        "category": { "type": "string", "minLength": 1 },
        "ok": { "type": "boolean" },
        "errorCodes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "warningCodes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "fixtureResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path", "ok", "summary", "errors", "warnings", "checks"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "ok": { "type": "boolean" },
        "summary": { "type": "object", "additionalProperties": true },
        "errors": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostic" }
        },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostic" }
        },
        "checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/check" }
        }
      }
    },
    "negativeSuite": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "ok", "cases", "problems"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "ok": { "type": "boolean" },
        "cases": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "ok", "expectedErrorCodes", "actualErrorCodes"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "ok": { "type": "boolean" },
              "expectedErrorCodes": {
                "type": "array",
                "items": { "type": "string" }
              },
              "actualErrorCodes": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "problems": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
