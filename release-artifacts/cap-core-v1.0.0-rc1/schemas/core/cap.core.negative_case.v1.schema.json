{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cap-spec.org/schemas/core/cap.core.negative_case.v1.schema.json",
  "title": "CAP-Core Negative Case Harness v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "case"],
  "properties": {
    "schema": { "const": "cap.core.negative_case.v1" },
    "case": { "type": "string", "minLength": 1 },
    "record": { "type": "object", "additionalProperties": true },
    "records": { "type": "object", "additionalProperties": true }
  },
  "anyOf": [
    { "required": ["record"] },
    { "required": ["records"] }
  ]
}
