{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cap-spec.org/schemas/core/cap.core.capability.v1.schema.json",
  "title": "CAP-Core Capability v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "id", "name", "inputs", "outputs", "sideEffects", "requiredBindings", "errorSemantics"],
  "properties": {
    "schema": { "const": "cap.core.capability.v1" },
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": ["string", "null"] },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/ioRef" }
    },
    "outputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/ioRef" }
    },
    "sideEffects": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requiredBindings": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["runtime", "resource", "service", "policy", "evidence", "digest", "transport", "data-plane", "schema"]
      }
    },
    "errorSemantics": { "type": ["string", "null"] },
    "profiles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "implementationBindings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "ioRef": {
      "type": "object",
      "additionalProperties": true,
      "required": ["role", "artifactKind"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "artifactKind": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "profile": { "type": ["string", "null"] }
      }
    }
  }
}
